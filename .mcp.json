{
  "mcpServers": {
    "petclinic-mcp": {
      "type": "sse",
      "url": "http://localhost:8090/sse",
      "headers": {
        "X-API-Key": "demo-key-1"
      }
    },

    "grafana": {
      "command": "uvx",
      "args": ["mcp-grafana"],
      "env": {
        "GRAFANA_URL": "http://localhost:3300",
        "GRAFANA_USERNAME": "admin",
        "GRAFANA_PASSWORD": "admin"
      }
      },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--output-dir", "/tmp/playwright",
        "--save-session"
      ]
    }
  }
}
