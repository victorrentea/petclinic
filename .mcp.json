{
  "mcpServers": {
    "petclinic-mcp": {
      "type": "sse",
      "url": "http://localhost:8080/sse",
      "headers": {
        "X-API-Key": "demo-key-1"
      }
    },
    "postgres-db": {
      "command": "npx",
      "args": [
        "-y",
        "@bytebase/dbhub",
        "--transport", "stdio",
        "--dsn", "postgres://petclinic:petclinic@localhost:5432/petclinic"
      ]
    },
    "grafana": {
      "command": "uvx",
      "args": ["mcp-grafana"],
      "env": {
        "GRAFANA_URL": "http://localhost:3300",
        "GRAFANA_USERNAME": "admin",
        "GRAFANA_PASSWORD": "admin"
      }
      },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--output-dir", "/tmp/playwright",
        "--save-session",
        "--save-trace"
      ]
    }
  }
}
