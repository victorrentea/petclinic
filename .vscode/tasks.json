{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Pull latest AI skills",
      "type": "shell",
      "command": "git -C \"$AI_CENTRAL_PATH\" pull --ff-only --quiet && ln -sfn \"$AI_CENTRAL_PATH/skills\" \"${workspaceFolder}/.github/skills\"",
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "silent",
        "close": true
      }
    }
  ]
}
