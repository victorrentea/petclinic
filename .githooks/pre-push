#!/usr/bin/env bash
set -e

ROOT="$(git rev-parse --show-toplevel)"
REMOTE="$1"

ZERO=0000000000000000000000000000000000000000

# ── Path gating: skip unless pushed commits touch backend / frontend / OpenAPI ─
needs_check=0
while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$ZERO" ] && continue  # branch deletion — nothing to verify

  if [ "$remote_sha" = "$ZERO" ]; then
    paths=$(git log --name-only --pretty=format: "$local_sha" --not --remotes="$REMOTE" 2>/dev/null || true)
  else
    paths=$(git log --name-only --pretty=format: "$remote_sha..$local_sha" 2>/dev/null || true)
  fi

  if printf '%s\n' "$paths" | grep -qE '^(petclinic-backend-ts/|petclinic-frontend/|openapi\.yaml$)'; then
    needs_check=1
    break
  fi
done

if [ "$needs_check" -eq 0 ]; then
  echo "[pre-push] ✓ No backend / frontend / OpenAPI changes — skipping guardrail checks."
  echo "✅ pre-push"
  exit 0
fi

# ── Backend: type-check via the production build ───────────────────────────
if [ -d "$ROOT/petclinic-backend-ts/node_modules" ]; then
  BE_OUT=$(mktemp)
  trap 'rm -f "$BE_OUT" "${SPECTRAL_OUT:-}" "${BUILD_OUT:-}"' EXIT
  echo "[pre-push] Building the backend (nest build)…"
  if ! npm --prefix "$ROOT/petclinic-backend-ts" run build --silent >"$BE_OUT" 2>&1; then
    tail -200 "$BE_OUT"
    echo "[pre-push] ❌ Backend build failed — push blocked."
    exit 1
  fi
else
  echo "[pre-push] ⚠️  petclinic-backend-ts/node_modules missing — skipping backend build."
  echo "[pre-push]    Install with: cd petclinic-backend-ts && npm install"
fi

# ── Spectral lint of the committed openapi.yaml ────────────────────────────
if command -v npm >/dev/null 2>&1 && [ -d "$ROOT/petclinic-frontend/node_modules/@stoplight/spectral-cli" ]; then
  SPECTRAL_OUT=$(mktemp)
  trap 'rm -f "${BE_OUT:-}" "$SPECTRAL_OUT" "${BUILD_OUT:-}"' EXIT
  if ! npm --prefix "$ROOT/petclinic-frontend" run lint:openapi --silent >"$SPECTRAL_OUT" 2>&1; then
    cat "$SPECTRAL_OUT"
    echo "[pre-push] ❌ Spectral found errors in openapi.yaml — push blocked."
    exit 1
  fi
else
  echo "[pre-push] ⚠️  Spectral CLI missing — skipping OpenAPI lint."
fi

# ── Frontend chain: openapi.yaml → api-types.ts → ng build ─────────────────
# Regenerates api-types.ts from openapi.yaml then runs ng build. A field
# add/rename in the API surfaces here as a TS error against stale frontend
# usages of the old type — push blocked.
if command -v npm >/dev/null 2>&1 && [ -d "$ROOT/petclinic-frontend/node_modules" ]; then
  BUILD_OUT=$(mktemp)
  trap 'rm -f "${BE_OUT:-}" "${SPECTRAL_OUT:-}" "$BUILD_OUT"' EXIT
  echo "[pre-push] Running frontend build (regenerates api-types.ts, then ng build)…"
  if ! npm --prefix "$ROOT/petclinic-frontend" run build --silent >"$BUILD_OUT" 2>&1; then
    tail -200 "$BUILD_OUT"
    echo "[pre-push] ❌ Frontend build failed against regenerated api-types.ts — push blocked."
    exit 1
  fi
  # Drift: api-types.ts in HEAD must match what generate:api just produced.
  if ! git diff --quiet HEAD -- "$ROOT/petclinic-frontend/src/app/generated/api-types.ts"; then
    git diff --stat HEAD -- "$ROOT/petclinic-frontend/src/app/generated/api-types.ts"
    echo "[pre-push] ❌ api-types.ts drifted from committed state — commit the regenerated file and push again."
    exit 1
  fi
else
  echo "[pre-push] ⚠️  npm or petclinic-frontend/node_modules missing — skipping api-types regen + ng build."
fi

echo "[pre-push] ✓ Guardrails passed."
echo "✅ pre-push"
