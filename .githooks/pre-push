#!/usr/bin/env bash
set -e

ROOT="$(git rev-parse --show-toplevel)"
REMOTE="$1"

ZERO=0000000000000000000000000000000000000000

# ── Path gating: skip unless pushed commits touch backend / OpenAPI / schema ─
needs_check=0
while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$ZERO" ] && continue  # branch deletion — nothing to verify

  if [ "$remote_sha" = "$ZERO" ]; then
    paths=$(git log --name-only --pretty=format: "$local_sha" --not --remotes="$REMOTE" 2>/dev/null || true)
  else
    paths=$(git log --name-only --pretty=format: "$remote_sha..$local_sha" 2>/dev/null || true)
  fi

  # Guard: a DB.sql change in the pushed range must carry a regenerated
  # DbSchema.puml (catches a `git commit --no-verify` that bypassed pre-commit).
  if printf '%s\n' "$paths" | grep -qx 'DB.sql' \
     && ! printf '%s\n' "$paths" | grep -qx 'petclinic-backend/docs/generated/DbSchema.puml'; then
    echo "[pre-push] ❌ DB.sql changed but petclinic-backend/docs/generated/DbSchema.puml was not regenerated."
    echo "[pre-push]    Run: ./petclinic-backend/docs/scripts/gen-db-schema-diagram.sh"
    echo "[pre-push]         git add petclinic-backend/docs/generated/DbSchema.puml"
    echo "[pre-push]    then amend/commit and push again (or avoid --no-verify so pre-commit handles it)."
    exit 1
  fi

  if printf '%s\n' "$paths" | grep -qE '^(petclinic-backend/|openapi\.yaml$|db\.sql$)'; then
    needs_check=1
    break
  fi
done

if [ "$needs_check" -eq 0 ]; then
  echo "[pre-push] ✓ No backend / OpenAPI / schema changes — skipping guardrail tests."
  echo "✅ pre-push"
  exit 0
fi

# ── Architecture artifacts + OpenAPI/JPA sync ──────────────────────────────
cd "$ROOT/petclinic-backend"
MVN_OUT=$(mktemp)
trap 'rm -f "$MVN_OUT"' EXIT
TESTS=(
  OpenApiExtractorTest
  PackagesArchTest
  C3ArchTest
  DomainModelExtractorTest
  DbSchemaExtractorTest
  JpaMatchesDBSchemaTest
)
TESTS_CSV=$(IFS=,; echo "${TESTS[*]}")
echo "[pre-push] Running guardrail tests (this may take ~20s)…"
if ! mvn -q test -Dtest="$TESTS_CSV" >"$MVN_OUT" 2>&1; then
  cat "$MVN_OUT"
  echo "[pre-push] ❌ Guardrail tests failed — push blocked."
  exit 1
fi

# ── Drift detection: regenerated artifacts must match HEAD ─────────────────
DRIFT_PATHS=(
  "$ROOT/petclinic-backend/docs/generated"
  "$ROOT/openapi.yaml"
  "$ROOT/db.sql"
)
if ! git diff --quiet HEAD -- "${DRIFT_PATHS[@]}"; then
  echo "[pre-push] ❌ Generated artifacts drifted from committed state:"
  git diff --stat HEAD -- "${DRIFT_PATHS[@]}"
  echo ""
  echo "[pre-push]    Commit the regenerated files and push again."
  exit 1
fi

# ── Spectral lint of the freshly regenerated openapi.yaml ──────────────────
if command -v npm >/dev/null 2>&1 && [ -d "$ROOT/petclinic-frontend/node_modules/@stoplight/spectral-cli" ]; then
  SPECTRAL_OUT=$(mktemp)
  trap 'rm -f "$MVN_OUT" "$SPECTRAL_OUT" "${BUILD_OUT:-}"' EXIT
  if ! npm --prefix "$ROOT/petclinic-frontend" run lint:openapi --silent >"$SPECTRAL_OUT" 2>&1; then
    cat "$SPECTRAL_OUT"
    echo "[pre-push] ❌ Spectral found errors in openapi.yaml — push blocked."
    exit 1
  fi
else
  echo "[pre-push] ⚠️  Spectral CLI missing — skipping OpenAPI lint."
  echo "[pre-push]    Install with: cd petclinic-frontend && npm install"
fi

# ── Frontend chain: openapi.yaml → api-types.ts → ng build ─────────────────
# Regenerates api-types.ts from the freshly-extracted openapi.yaml, then ng build.
# Any field add/rename on the Java side surfaces here as a TS error against stale
# frontend usages of the old type — push blocked.
if command -v npm >/dev/null 2>&1 && [ -d "$ROOT/petclinic-frontend/node_modules" ]; then
  BUILD_OUT=$(mktemp)
  trap 'rm -f "$MVN_OUT" "$SPECTRAL_OUT" "$BUILD_OUT"' EXIT
  echo "[pre-push] Running npm run build (regenerates api-types.ts, then ng build)…"
  if ! npm --prefix "$ROOT/petclinic-frontend" run build --silent >"$BUILD_OUT" 2>&1; then
    tail -200 "$BUILD_OUT"
    echo "[pre-push] ❌ Frontend build failed against regenerated api-types.ts — push blocked."
    exit 1
  fi
  # Drift: api-types.ts in HEAD must match what generate:api just produced.
  if ! git diff --quiet HEAD -- "$ROOT/petclinic-frontend/src/app/generated/api-types.ts"; then
    git diff --stat HEAD -- "$ROOT/petclinic-frontend/src/app/generated/api-types.ts"
    echo "[pre-push] ❌ api-types.ts drifted from committed state — commit the regenerated file and push again."
    exit 1
  fi
else
  echo "[pre-push] ⚠️  npm or petclinic-frontend/node_modules missing — skipping api-types regen + ng build."
  echo "[pre-push]    Install with: cd petclinic-frontend && npm install"
fi

echo "[pre-push] ✓ Guardrails passed."
echo "✅ pre-push"
