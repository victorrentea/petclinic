#!/usr/bin/env bash
set -e

ROOT="$(git rev-parse --show-toplevel)"

echo "[pre-commit] Checking line length (max 120) on staged Java files..."
violations=$(git -C "$ROOT" diff --cached --unified=0 --diff-filter=AM -- '*.java' | awk '
  /^diff --git / {
    file = $0
    sub(/^diff --git a\//, "", file)
    sub(/ b\/.*$/, "", file)
    next
  }
  /^\+\+\+/ { next }
  /^\+/ {
    line = substr($0, 2)
    if (length(line) > 120) {
      printf "  %s: %d chars: %s\n", file, length(line), line
      found = 1
    }
  }
  END { exit found ? 1 : 0 }
') || {
  echo "[pre-commit] FAILED: staged lines over 120 characters:"
  echo "$violations"
  exit 1
}

echo "[pre-commit] Regenerating architecture artifacts..."
cd "$ROOT/petclinic-backend"
mvn -q test -Dtest=C4ModelExtractorTest,DomainModelExtractorTest,DomainModelDiagramExtractorTest

git add "$ROOT/petclinic-backend/docs/generated"
echo "[pre-commit] C4 model DSL and domain model diagram updated and staged."

STAGED=$(git -C "$ROOT" diff --cached --name-only --diff-filter=AM)

if echo "$STAGED" | grep -q '^petclinic-backend/'; then
  echo "[pre-commit] Backend changes detected — running fast unit tests..."
  cd "$ROOT/petclinic-backend"
  mvn -q test -Dtest=ArchitectureTest,ValidatorTests
  echo "[pre-commit] Backend unit tests passed."

  if echo "$STAGED" | grep -q '\.java$'; then
    echo "[pre-commit] Java files staged — running PMD..."
    mvn -q pmd:check
    echo "[pre-commit] PMD passed."
  fi
fi

if echo "$STAGED" | grep -q '^petclinic-frontend/'; then
  echo "[pre-commit] Frontend changes detected — running unit tests..."
  cd "$ROOT/petclinic-frontend"
  npm run test-headless
  echo "[pre-commit] Frontend unit tests passed."
fi
