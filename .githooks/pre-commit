#!/usr/bin/env bash
set -e

ROOT="$(git rev-parse --show-toplevel)"

# ── Secrets scan (gitleaks) ────────────────────────────────────────────────
if command -v gitleaks >/dev/null 2>&1; then
  echo "[pre-commit] Scanning staged changes for secrets (gitleaks)..."
  if ! gitleaks protect --staged --redact --no-banner; then
    echo ""
    echo "[pre-commit] ❌ Secrets detected in staged changes — commit blocked."
    echo "[pre-commit]    Remove the secret, rotate it if it was real, then re-stage."
    exit 1
  fi
else
  echo "[pre-commit] ⚠️  gitleaks not installed — skipping secret scan."
  echo "[pre-commit]    Install with: brew install gitleaks"
fi

echo "[pre-commit] Regenerating architecture artifacts and verifying OpenAPI sync..."
cd "$ROOT/petclinic-backend"
mvn -q test -Dtest=C4ModelExtractorTest,DomainModelExtractorTest,DomainModelDiagramExtractorTest,OpenApiSyncTest,JpaSchemaValidateTest

git add "$ROOT/petclinic-backend/docs/generated"
echo "[pre-commit] C4 model DSL and domain model diagram updated and staged."

# ── Frontend: regenerate TS types from openapi.yaml ────────────────────────
if command -v npm >/dev/null 2>&1 && [ -d "$ROOT/petclinic-frontend/node_modules" ]; then
  echo "[pre-commit] Regenerating TS types from openapi.yaml..."
  npm --prefix "$ROOT/petclinic-frontend" run generate:api --silent
  git add "$ROOT/petclinic-frontend/src/app/generated/api-types.ts"
  echo "[pre-commit] api-types.ts regenerated and staged."
else
  echo "[pre-commit] ⚠️  npm or petclinic-frontend/node_modules missing — skipping TS-types regen."
  echo "[pre-commit]    Install with: cd petclinic-frontend && npm install"
fi