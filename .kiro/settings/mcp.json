{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "autoApprove": [
        "list_pages",
        "navigate_page",
        "take_snapshot",
        "list_console_messages",
        "list_network_requests",
        "get_network_request",
        "take_screenshot"
      ]
    },
    "github": {
      "command": "uvx",
      "args": [
        "mcp-server-github"
      ],
      "autoApprove": []
    }
  }
}