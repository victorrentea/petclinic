{
  "permissions": {
    "deny": [
      "Bash(git commit --no-verify*)",
      "Bash(git push --no-verify*)"
    ],
    "ask": [
      "Edit(.claude/settings.json)",
      "Write(.claude/settings.json)",
      "Edit(.claude/settings.local.json)",
      "Write(.claude/settings.local.json)",
      "Edit(.githooks/*)",
      "Write(.githooks/*)",
      "Bash(git add .githooks*)",
      "Edit(.github/workflows/*)",
      "Write(.github/workflows/*)",
      "Edit(petclinic-backend-ts/src/migrations/*)",
      "Write(petclinic-backend-ts/src/migrations/*)",
      "Edit(petclinic-backend-ts/docs/packages.puml)",
      "Write(petclinic-backend-ts/docs/packages.puml)",
      "Edit(petclinic-backend-ts/test/guardrails/package-deps.ts)",
      "Write(petclinic-backend-ts/test/guardrails/package-deps.ts)",
      "Edit(.github/CODEOWNERS)",
      "Write(.github/CODEOWNERS)",
      "Edit(**/package.json)",
      "Write(**/package.json)"
    ]
  },
  "skillOverrides": {
    "add-field": "user-invocable-only",
    "update-config": "user-invocable-only"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"## Repo state\\nBranch: $(git branch --show-current)\\n\\nUncommitted changes:\\n$(git status --short)\\n\\nLast 5 commits:\\n$(git log --oneline -5)\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__postgres-db__*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-mcp-db-ratelimit.sh\""
          }
        ]
      }
    ]
  }
}
