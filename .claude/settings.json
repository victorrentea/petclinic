{
  "permissions": {
    "ask": [
      "Bash(git commit --no-verify*)",
      "Bash(git push --no-verify*)",
      "Bash(git add .githooks*)",
      "Edit(.githooks/*)",
      "Edit(petclinic-backend/docs/*)",
      "Edit(openapi.yaml)",
      "Write(openapi.yaml)",
      "Edit(.github/workflows/*)",
      "Write(.github/workflows/*)",
      "Edit(petclinic-backend/src/test/java/victor/training/petclinic/guardrail/*)",
      "Write(petclinic-backend/src/test/java/victor/training/petclinic/guardrail/*)",
      "Edit(petclinic-backend/.coverage-baseline)",
      "Write(petclinic-backend/.coverage-baseline)",
      "Edit(.github/CODEOWNERS)",
      "Write(.github/CODEOWNERS)",
      "Edit(.claude/settings.json)",
      "Write(.claude/settings.json)",
      "Edit(.claude/settings.local.json)",
      "Write(.claude/settings.local.json)",
      "Edit(**/pom.xml)",
      "Write(**/pom.xml)",
      "Edit(petclinic-frontend/package.json)",
      "Write(petclinic-frontend/package.json)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__petclinic-db__*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-mcp-db-ratelimit.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-edit-spotless.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-java-fqcn-check.sh\""
          }
        ]
      }
    ]
  }
}
