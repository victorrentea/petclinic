# Secrets (defense-in-depth; gitleaks is the primary guard in pre-commit)
*.env
!**/.env.example

# OS / IDE (apply to any module)
.DS_Store
Thumbs.db
.idea/
*.iml
.classpath
.project
.settings/
.factorypath
.java-version
.tool-versions
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Maven / Java build output (any module)
target/
**/.jqwik-database

# Node (any module)
node_modules/

# git worktrees
.worktrees/

# petclinic-database (embedded Postgres)
petclinic-database/data/
petclinic-database/dependency-reduced-pom.xml

# petclinic-ui-test (Playwright)
petclinic-ui-test/test-results/
petclinic-ui-test/playwright-report/
petclinic-ui-test/playwright/.cache/

# petclinic-frontend (Angular)
petclinic-frontend/dist
petclinic-frontend/tmp
petclinic-frontend/out-tsc
petclinic-frontend/.angular
petclinic-frontend/.angular/cache
petclinic-frontend/.sass-cache
petclinic-frontend/.c9/
petclinic-frontend/connect.lock
petclinic-frontend/coverage
petclinic-frontend/libpeerconnection.log
petclinic-frontend/npm-debug.log
petclinic-frontend/testem.log
petclinic-frontend/typings

# petclinic-backend
petclinic-backend/src/test/postman/reports/
petclinic-backend/.tools/

# Generated diagram renders — sources (.puml/.dsl) are tracked; renders viewed via PlantUML proxy URLs (see docs/generated/INDEX.md)
petclinic-backend/docs/generated/**/*.svg
petclinic-backend/docs/generated/**/*.png

# qa
/qa/test-results/screenshots/

# misc
__pycache__/
.github/skills
/.playwright-mcp
