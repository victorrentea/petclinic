@startuml
title <size:24>Container View: PetClinic</size>\n<size:24>Containers inside PetClinic</size>

set separator none
left to right direction

<style>
  root {
    BackgroundColor: #ffffff
    FontColor: #444444
  }
</style>

!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Container>

Person(PetOwner, "Pet Owner", $descr="Manages their pets and appointments", $tags="", $link="")
Person(Veterinarian, "Veterinarian", $descr="Provides veterinary care", $tags="", $link="")

System_Boundary("PetClinic_boundary", "PetClinic", $tags="") {
  Container(PetClinic.Frontend, "Frontend", $techn="Angular", $descr="Single-page application", $tags="", $link="")
  Container(PetClinic.Backend, "Backend", $techn="Java / Spring Boot", $descr="REST API", $tags="", $link="")
  Container(PetClinic.Database, "Database", $techn="PostgreSQL", $descr="Stores all data", $tags="", $link="")
}

Rel(Veterinarian, PetClinic.Frontend, "Uses", $techn="", $tags="", $link="")
Rel(PetClinic.Frontend, PetClinic.Backend, "REST API calls", $techn="HTTPS/JSON", $tags="", $link="")
Rel(PetClinic.Backend, PetClinic.Database, "Reads/writes", $techn="JPA", $tags="", $link="")
Rel(PetOwner, PetClinic.Frontend, "Uses", $techn="", $tags="", $link="")

SHOW_LEGEND(true)
hide stereotypes
@enduml