@startuml
title <size:24>Component View: PetClinic - Backend</size>\n<size:24>Repository Layer — nearest neighbours</size>

set separator none
left to right direction

<style>
  root {
    BackgroundColor: #ffffff
    FontColor: #444444
  }
</style>

!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Component>

System_Boundary("PetClinic_boundary", "PetClinic", $tags="") {
  Container_Boundary("PetClinic.Backend_boundary", "Backend", $tags="") {
    Component(PetClinic.Backend.RESTLayer, "REST Layer", $techn="Spring MVC", $descr="HTTP endpoints, DTOs, error handlers", $tags="", $link="")
    Component(PetClinic.Backend.DomainModel, "Domain Model", $techn="JPA", $descr="JPA entities", $tags="", $link="")
    Component(PetClinic.Backend.RepositoryLayer, "Repository Layer", $techn="Spring Data", $descr="Spring Data JPA repositories", $tags="", $link="")
  }

}

Rel(PetClinic.Backend.RESTLayer, PetClinic.Backend.DomainModel, "", $techn="", $tags="", $link="")
Rel(PetClinic.Backend.RESTLayer, PetClinic.Backend.RepositoryLayer, "", $techn="", $tags="", $link="")
Rel(PetClinic.Backend.RepositoryLayer, PetClinic.Backend.DomainModel, "", $techn="", $tags="", $link="")

SHOW_LEGEND(true)
hide stereotypes
@enduml