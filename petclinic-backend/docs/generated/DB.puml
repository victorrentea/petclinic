@startuml
title Database Schema (ER)
caption Generated from DB.sql — red = changed in this commit
hide circle
skinparam linetype ortho

entity "owners" as owners {
{field} id : int <<PK>>
{field} first_name : text
{field} last_name : text
{field} address : text
{field} city : text
{field} telephone : text
-- indexes --
{field} <color:red>idx_owners_address : address</color>
{field} <color:red>idx_owners_city : city</color>
{field} <color:red>idx_owners_last_name_first_name : last_name, first_name</color>
{field} <color:red>idx_owners_last_name_pattern : last_name text_pattern_ops</color>
{field} <color:red>idx_owners_telephone : telephone</color>
}

entity "pets" as pets {
{field} id : int <<PK>>
{field} name : text
{field} birth_date : date
{field} type_id : int <<FK>> not null
{field} owner_id : int <<FK>>
-- indexes --
{field} pets_name_idx : name
{field} pets_owner_id_idx : owner_id
}

entity "roles" as roles {
{field} id : int <<PK>>
{field} username : varchar(20) <<FK>> not null
{field} role : varchar(20) not null
}

entity "specialties" as specialties {
{field} id : int <<PK>>
{field} name : text
{field} description : text
-- indexes --
{field} specialties_name_idx : name
}

entity "types" as types {
{field} id : int <<PK>>
{field} name : text
-- indexes --
{field} types_name_idx : name
}

entity "users" as users {
{field} username : varchar(20) <<PK>>
{field} password : varchar(60) not null
{field} enabled : boolean not null
}

entity "vet_specialties" as vet_specialties {
{field} vet_id : int <<FK>> not null
{field} specialty_id : int <<FK>> not null
}

entity "vets" as vets {
{field} id : int <<PK>>
{field} first_name : text
{field} last_name : text
-- indexes --
{field} vets_last_name_idx : last_name
}

entity "visits" as visits {
{field} id : int <<PK>>
{field} pet_id : int <<FK>>
{field} visit_date : date
{field} description : text
{field} visit_time : time
-- indexes --
{field} visits_pet_id_idx : pet_id
}


owners ||--o{ pets : owner_id
pets ||--o{ visits : pet_id
specialties ||--o{ vet_specialties : specialty_id
types ||--o{ pets : type_id
users ||--o{ roles : username
vets ||--o{ vet_specialties : vet_id

@enduml
