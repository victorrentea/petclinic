@startuml
title <size:24>Component View: PetClinic Backend - REST API</size>\n<size:24>Mapper layer: incoming (REST Controllers) and outgoing (Domain Model) dependencies</size>

set separator none
top to bottom direction

<style>
  root {
    BackgroundColor: #ffffff
    FontColor: #444444
  }
</style>

!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Component>

System_Boundary("PetClinicBackend_boundary", "PetClinic Backend", $tags="") {
  Container_Boundary("PetClinicBackend.RESTAPI_boundary", "REST API", $tags="") {
    Component(PetClinicBackend.RESTAPI.RESTControllers, "REST Controllers", $techn="Spring MVC", $descr="Handles HTTP requests, delegates to mappers and repositories", $tags="", $link="")
    Component(PetClinicBackend.RESTAPI.Mappers, "Mappers", $techn="MapStruct", $descr="Converts JPA entities to DTOs and back", $tags="", $link="")
    Component(PetClinicBackend.RESTAPI.DomainModel, "Domain Model", $techn="JPA / Hibernate", $descr="JPA entities: Owner, Pet, Vet, Visit, etc.", $tags="", $link="")
  }

}

Rel(PetClinicBackend.RESTAPI.RESTControllers, PetClinicBackend.RESTAPI.Mappers, "Transforms entities via", $techn="", $tags="", $link="")
Rel(PetClinicBackend.RESTAPI.RESTControllers, PetClinicBackend.RESTAPI.DomainModel, "Uses directly", $techn="", $tags="", $link="")
Rel(PetClinicBackend.RESTAPI.Mappers, PetClinicBackend.RESTAPI.DomainModel, "Converts entities to DTOs", $techn="", $tags="", $link="")

SHOW_LEGEND(true)
hide stereotypes
@enduml